{
  "name": "@aizona/aza-protocol",
  "version": "0.1.0",
  "description": "AIZona AZA Protocol — agent-to-agent messaging, identity, task management, and team orchestration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "canonicalize": "^2.1.0",
    "ioredis": "^5.9.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "keywords": ["ai", "agents", "aza", "protocol", "aizona", "adk", "a2a", "identity"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-zona/adk.git",
    "directory": "packages/aza-protocol"
  },
  "homepage": "https://github.com/ai-zona/adk#readme",
  "bugs": {
    "url": "https://github.com/ai-zona/adk/issues"
  }
}
