{
  "name": "@aizona/adk-cli",
  "version": "0.1.0",
  "description": "AIZona ADK CLI — Scaffold, deploy, and manage AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aizona": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@aizona/adk": "workspace:*",
    "commander": "^13.1.0"
  },
  "optionalDependencies": {
    "@aizona/adk-server": "workspace:*"
  },
  "devDependencies": {
    "@aizona/adk-server": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "keywords": ["ai", "agents", "cli", "scaffolding"],
  "license": "MIT"
}
