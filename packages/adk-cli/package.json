{
  "name": "@aizonaai/adk-cli",
  "version": "0.1.0",
  "description": "AIZona ADK CLI \u2014 Scaffold, deploy, and manage AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aizona": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@aizonaai/adk": "workspace:*",
    "commander": "^13.1.0"
  },
  "optionalDependencies": {
    "@aizonaai/adk-server": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "scaffolding",
    "aizona",
    "adk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-zona/adk.git",
    "directory": "packages/adk-cli"
  },
  "homepage": "https://github.com/ai-zona/adk#readme",
  "bugs": {
    "url": "https://github.com/ai-zona/adk/issues"
  },
  "peerDependencies": {
    "@aizonaai/adk-server": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@aizonaai/adk-server": {
      "optional": true
    }
  }
}
