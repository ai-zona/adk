{
  "name": "@aizona/aza-client",
  "version": "0.1.0",
  "description": "AIZona AZA Agent Client \u2014 connect external agents to the AIZona platform",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@aizona/aza-protocol": "workspace:*",
    "ioredis": "^5.9.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "ai",
    "agents",
    "aza",
    "aizona",
    "adk",
    "protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-zona/adk.git",
    "directory": "packages/aza-client"
  },
  "homepage": "https://github.com/ai-zona/adk#readme",
  "bugs": {
    "url": "https://github.com/ai-zona/adk/issues"
  }
}
